# Скопируйте в .env и заполните под своё окружение.

# Секретный ключ Flask (ОБЯЗАТЕЛЬНО смените в проде!)
SECRET_KEY=change-me-to-a-long-random-string

# Среда: development | production
FLASK_ENV=development

# Публичный адрес для ссылок-приглашений и QR (важно для рассылки родителям).
# Например: https://invite.ccu.kz  — если не задан, берётся адрес запроса.
# PUBLIC_BASE_URL=https://invite.ccu.kz

# Сколько дней действует приглашение (по умолчанию 30 — месяц)
INVITE_VALID_DAYS=30

# Лимит гостей на одного студента
MAX_GUESTS_PER_STUDENT=3

# Вместимость зала (0 — без ограничения)
VENUE_CAPACITY=0

# Часовой пояс для отображения дат (Казахстан = 5)
DISPLAY_TZ_OFFSET=5

# Брендинг
COLLEGE_NAME=Колледж Каспийского университета
EVENT_TITLE=Торжественная церемония вручения дипломов

# Запуск HTTPS локально (нужно для доступа к камере на телефоне по LAN)
# SSL_ADHOC=1

# ─────────────────────────────────────────────────────────────
# ДЕПЛОЙ (Railway и др.)
# ─────────────────────────────────────────────────────────────
# Среда для прода (включает secure-cookie): production
# FLASK_ENV=production

# Где хранить SQLite на Railway — путь на Volume (иначе база сбросится при редеплое!)
# DATABASE_URL=sqlite:////data/ccu.db
# (или подключите плагин Postgres — Railway сам задаст DATABASE_URL)

# Учётка администратора, создаётся на деплое скриптом scripts/release.py.
# Если ADMIN_PASSWORD не задан на первом деплое — пароль сгенерируется и попадёт в лог.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=задайте-надёжный-пароль
# SCANNER_USERNAME=scanner
# SCANNER_PASSWORD=задайте-надёжный-пароль

